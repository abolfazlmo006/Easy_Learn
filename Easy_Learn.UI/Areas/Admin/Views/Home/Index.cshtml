@model IEnumerable<Easy_Learn.UI.ViewModels.CourseVM.CourseDetailVM>

@{
    ViewData["Title"] = "Index";
}

@section css{
    <link href="~/css/course.css" rel="stylesheet" />
}

<h1>Course</h1>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="div-shadow-smswiper">
            <div class="div-flex-20">
                <div class="div-px">
                    <div class="div-flex-21">
                        <div class="span-flex-wrapper">
                            <div class="span-flex-4">
                                <div class="text-wrapper-17">در حال برگزاری</div>
                                <img class="SVG-15" src="~/Images/dot-blue.svg">
                            </div>
                        </div>
                    </div>
                    <div class="div-wrapper-4">
                        <div class="link-23">
                            <p class="text-wrapper-33">@item.Name</p>
                        </div>
                    </div>
                    <div class="div-wrapper-4">
                        <div class="p-mb">
                            <p class="text-wrapper-34 bug-txt">
                                @item.Short_Description
                            </p>
                        </div>
                    </div>
                </div>
                <div class="div-3" style="position: absolute;top: 220px;left: 0px;">
                    <div class="div-pb-2 w-100">
                        <div class="div-2 w-100">
                            <div class="div-flex-23 d-flex">
                                @if (!item.IsFree)
                                {
                                    <img class="SVG-17" src="~/Images/TOMAN.svg">
                                    <div class="span-text-biscay">
                                        <div class="text-wrapper-37">@item.Price.ToString("0")</div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="div-flex-24">
                        <div class="link-24">
                            <a asp-action="Details" asp-route-Id="@item.Id">
                                <div class="span-2">
                                    <div class="text-wrapper-40">مشاهده اطلاعات دوره</div>
                                </div>
                                <img class="SVG-margin" src="~/Images/Enter-blue.svg">
                            </a>
                        </div>
                    </div>

                    <div style="text-align:center">
                        <a asp-area="Admin" asp-controller="Course" asp-action="Verify" asp-route-Id="@item.Id">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-patch-check" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M10.354 6.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7 8.793l2.646-2.647a.5.5 0 0 1 .708 0" />
                                <path d="m10.273 2.513-.921-.944.715-.698.622.637.89-.011a2.89 2.89 0 0 1 2.924 2.924l-.01.89.636.622a2.89 2.89 0 0 1 0 4.134l-.637.622.011.89a2.89 2.89 0 0 1-2.924 2.924l-.89-.01-.622.636a2.89 2.89 0 0 1-4.134 0l-.622-.637-.89.011a2.89 2.89 0 0 1-2.924-2.924l.01-.89-.636-.622a2.89 2.89 0 0 1 0-4.134l.637-.622-.011-.89a2.89 2.89 0 0 1 2.924-2.924l.89.01.622-.636a2.89 2.89 0 0 1 4.134 0l-.715.698a1.89 1.89 0 0 0-2.704 0l-.92.944-1.32-.016a1.89 1.89 0 0 0-1.911 1.912l.016 1.318-.944.921a1.89 1.89 0 0 0 0 2.704l.944.92-.016 1.32a1.89 1.89 0 0 0 1.912 1.911l1.318-.016.921.944a1.89 1.89 0 0 0 2.704 0l.92-.944 1.32.016a1.89 1.89 0 0 0 1.911-1.912l-.016-1.318.944-.921a1.89 1.89 0 0 0 0-2.704l-.944-.92.016-1.32a1.89 1.89 0 0 0-1.912-1.911z" />
                            </svg>
                        </a>
                        <a asp-area="Admin" asp-controller="Course" asp-action="Delete" asp-route-Id="@item.Id">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-trash3 text-danger" viewBox="0 0 16 16">
                                <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5" />
                            </svg>
                        </a>
                    </div>
                </div>
            </div>
            <div class="div-absolute">
                <div class="link-25">
                    <div style="background-image: url(./Images/9b04K1DH2DpNew697kBVLIJ9bdeIISvWAUSb3nW6.webp);"
                         class="div-15"></div>
                </div>
            </div>
        </div>
    }
</div>