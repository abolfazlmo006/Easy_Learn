@using System.Security.Claims
@inject IClient _client

<!DOCTYPE html>
<html lang="fa" dir="rtl">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Easy_Learn.UI</title>
    <link rel="stylesheet" href="~/CSS/reset.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.7/dist/sweetalert2.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css"
          integrity="sha384-nU14brUcp6StFntEOOEBvcJm4huWjB0OcIeQ3fltAfSmuZFrkAif0T+UtNGlKKQv" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/vazir-font/30.1.0/font-face.css"
          integrity="sha512-ZHFuHiK3EA1uh2tx7nB0j9HyXR/IAFW24KVNFGjY8QIjtDKHmcowjUyObXF40wYrG25+kECHEbH8rL+HbvRwYA=="
          crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="icon" type="image/png" href="~/EasyLearn.ico">
    <link href="~/css/user.css" rel="stylesheet" />
    <link href="~/css/global.css" rel="stylesheet" />
    <link href="~/css/navnew.css" rel="stylesheet" />
    @await RenderSectionAsync("css", false)
</head>

<body>
    <nav class="navbar navbar-expand-md mt-3" aria-label="Eighth navbar example">
        <div class="container-md" style="position: relative;">
            <a asp-action="index" asp-controller="home"><img class="Logo" src="~/Images/easy-learn.png"></a>
            @if (!User.Identity.IsAuthenticated)
            {
                <div class="div-left-margin">
                    <div class="div-left">
                        <div class="div-flex-33">
                            <a asp-action="register" asp-controller="Authentication">
                                <div class="link-33">
                                    <img class="span-mr" src="~/Images/signout.svg">
                                    <div class="span-hd-fec">
                                        <div class="text-wrapper-56">عضویت</div>
                                    </div>
                                </div>
                            </a>
                            <a asp-action="login" asp-controller="Authentication">
                                <div class="link-34">
                                    <img class="span-mr" src="~/Images/login.svg">
                                    <div class="span-hidden-3">
                                        <div class="text-wrapper-57">ورود</div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="nav-item dropdown vair" style="margin-left:32px;order: 1">
                    <a class="nav-link dropdown-toggle text-black" role="button"
                       data-bs-toggle="dropdown" aria-expanded="false">
                        @User.FindFirstValue(ClaimTypes.GivenName)
                        <img class="rounded-circle" style="width:45px; height:45px;" src="~/Images/9b04K1DH2DpNew697kBVLIJ9bdeIISvWAUSb3nW6.webp" />
                    </a>
                    <ul class="dropdown-menu dropdown-menu vazir">
                        <li><a class="dropdown-item" asp-controller="User" asp-action="Index">پنل کاربری</a></li>
                        <li>
                            <a class="dropdown-item" asp-controller="Cart" asp-action="ShowCart">
                                سبد خرید
                            </a>
                        </li>
                        <li> <form method="post" asp-controller="Authentication" asp-action="LogOut"><input type="submit" value="خروج" /></form></li>
                    </ul>
                </div>
                <div class="nav-item mt-0 mx-0 not" onmouseenter="shakeBell()" style="order:1;position:relative">
                    <a asp-action="Notifications" asp-controller="User" class="text-black">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" class="bi bi-bell-fill" viewBox="0 0 16 16">
                            <path d="M8 16a2 2 0 0 0 2-2H6a2 2 0 0 0 2 2m.995-14.901a1 1 0 1 0-1.99 0A5 5 0 0 0 3 6c0 1.098-.5 6-2 7h14c-1.5-1-2-5.902-2-7 0-2.42-1.72-4.44-4.005-4.901" />
                        </svg>
                    </a>
                </div>
            }
            <button class="navbar-toggler btn-menue" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarsExample07" aria-controls="navbarsExample07" aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarsExample07" style="margin-top: -17px;">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 vazir center">
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" asp-controller="course" asp-action="index">دوره ها</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link disabled">بلاگ</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"
                           aria-expanded="false">گروه ها</a>
                        <ul class="dropdown-menu">
                            @foreach (var item in await _client.GetAsync())
                            {
                                <li><a class="dropdown-item" asp-controller="course" asp-action="category" asp-route-Id="@item.Id">@item.Title</a></li>
                            }
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="d-lg-flex">
        <div class="col-12 col-lg-2">
            <div style="margin: 20px 10% 0px">
                <a class="text-black" asp-action="index" asp-controller="user">
                    <div class="d-flex side-item side-item-1" style="gap: 10%">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-info-square mt-2" viewBox="0 0 16 16">
                            <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z" />
                            <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0" />
                        </svg>
                        <p class="Yekan-Bakh-FaNum mt-1" style="font-size: 1.3rem">
                            صفحه اصلی پنل
                        </p>
                    </div>
                </a>
                <a class="text-black" asp-action="edit" asp-controller="user">
                    <div class="d-flex side-item side-item-2" style="gap: 10%">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-square mt-2" viewBox="0 0 16 16">
                            <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z" />
                            <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z" />
                        </svg>
                        <p class="Yekan-Bakh-FaNum mt-1" style="font-size: 1.3rem">
                            ویرایش اطلاعات
                        </p>
                    </div>
                </a>
                <a class="text-black" asp-action="comments" asp-controller="user">
                    <div class="d-flex side-item side-item-3" style="gap: 10%">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chat-square-text mt-2" viewBox="0 0 16 16">
                            <path d="M14 1a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1h-2.5a2 2 0 0 0-1.6.8L8 14.333 6.1 11.8a2 2 0 0 0-1.6-.8H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2.5a1 1 0 0 1 .8.4l1.9 2.533a1 1 0 0 0 1.6 0l1.9-2.533a1 1 0 0 1 .8-.4H14a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z" />
                            <path d="M3 3.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5M3 6a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9A.5.5 0 0 1 3 6m0 2.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5" />
                        </svg>
                        <p class="Yekan-Bakh-FaNum mt-1" style="font-size: 1.3rem">
                            نظر ها
                        </p>
                    </div>
                </a>

                <a class="text-black" asp-action="questions" asp-controller="user">
                    <div class="d-flex side-item side-item-4" style="gap: 10%">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-question-square mt-2" viewBox="0 0 16 16">
                            <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z" />
                            <path d="M5.255 5.786a.237.237 0 0 0 .241.247h.825c.138 0 .248-.113.266-.25.09-.656.54-1.134 1.342-1.134.686 0 1.314.343 1.314 1.168 0 .635-.374.927-.965 1.371-.673.489-1.206 1.06-1.168 1.987l.003.217a.25.25 0 0 0 .25.246h.811a.25.25 0 0 0 .25-.25v-.105c0-.718.273-.927 1.01-1.486.609-.463 1.244-.977 1.244-2.056 0-1.511-1.276-2.241-2.673-2.241-1.267 0-2.655.59-2.75 2.286m1.557 5.763c0 .533.425.927 1.01.927.609 0 1.028-.394 1.028-.927 0-.552-.42-.94-1.029-.94-.584 0-1.009.388-1.009.94" />
                        </svg>
                        <p class="Yekan-Bakh-FaNum mt-1" style="font-size: 1.3rem">
                            پرسش و پاسخ ها
                        </p>
                    </div>
                </a>
                <a class="text-black" asp-controller="User" asp-action="Notifications">
                    <div class="d-flex side-item side-item-notif" style="gap: 10%">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-bell mt-2" viewBox="0 0 16 16">
                            <path d="M8 16a2 2 0 0 0 2-2H6a2 2 0 0 0 2 2M8 1.918l-.797.161A4 4 0 0 0 4 6c0 .628-.134 2.197-.459 3.742-.16.767-.376 1.566-.663 2.258h10.244c-.287-.692-.502-1.49-.663-2.258C12.134 8.197 12 6.628 12 6a4 4 0 0 0-3.203-3.92zM14.22 12c.223.447.481.801.78 1H1c.299-.199.557-.553.78-1C2.68 10.2 3 6.88 3 6c0-2.42 1.72-4.44 4.005-4.901a1 1 0 1 1 1.99 0A5 5 0 0 1 13 6c0 .88.32 4.2 1.22 6" />
                        </svg>
                        <p class="Yekan-Bakh-FaNum mt-1" style="font-size: 1.3rem">
                            اعلانات
                        </p>
                    </div>
                </a>
                <a class="text-black" asp-controller="Cart" asp-action="showcart">
                    <div class="d-flex side-item side-item-6" style="gap: 10%">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-cart4 mt-2" viewBox="0 0 16 16">
                            <path d="M0 2.5A.5.5 0 0 1 .5 2H2a.5.5 0 0 1 .485.379L2.89 4H14.5a.5.5 0 0 1 .485.621l-1.5 6A.5.5 0 0 1 13 11H4a.5.5 0 0 1-.485-.379L1.61 3H.5a.5.5 0 0 1-.5-.5M3.14 5l.5 2H5V5zM6 5v2h2V5zm3 0v2h2V5zm3 0v2h1.36l.5-2zm1.11 3H12v2h.61zM11 8H9v2h2zM8 8H6v2h2zM5 8H3.89l.5 2H5zm0 5a1 1 0 1 0 0 2 1 1 0 0 0 0-2m-2 1a2 2 0 1 1 4 0 2 2 0 0 1-4 0m9-1a1 1 0 1 0 0 2 1 1 0 0 0 0-2m-2 1a2 2 0 1 1 4 0 2 2 0 0 1-4 0" />
                        </svg>
                        <p class="Yekan-Bakh-FaNum mt-1" style="font-size: 1.3rem">
                            سبد خرید
                        </p>
                    </div>
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <a class="text-black" asp-area="Admin" asp-action="index" asp-controller="Home">
                        <div class="d-flex side-item side-item-7" style="gap: 10%">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-fill mt-2" viewBox="0 0 16 16">
                                <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6" />
                            </svg>
                            <p class="Yekan-Bakh-FaNum mt-1" style="font-size: 1.3rem">
                                پنل مدیر
                            </p>
                        </div>
                    </a>
                }
                @if (User.IsInRole("Teacher"))
                {
                    <a class="text-black" asp-action="index" asp-controller="Teacher">
                        <div class="d-flex side-item side-item-8" style="gap: 10%">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-fill mt-2" viewBox="0 0 16 16">
                                <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6" />
                            </svg>
                            <p class="Yekan-Bakh-FaNum mt-1" style="font-size: 1.3rem">
                                پنل مدرس
                            </p>
                        </div>
                    </a>
                }
                <form method="post" id="logout-form" asp-controller="Authentication" asp-action="logout">

                    <div class="d-flex side-item side-item-5" style="gap: 10%">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-box-arrow-left mt-2" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M6 12.5a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 0-.5-.5h-8a.5.5 0 0 0-.5.5v2a.5.5 0 0 1-1 0v-2A1.5 1.5 0 0 1 6.5 2h8A1.5 1.5 0 0 1 16 3.5v9a1.5 1.5 0 0 1-1.5 1.5h-8A1.5 1.5 0 0 1 5 12.5v-2a.5.5 0 0 1 1 0z" />
                            <path fill-rule="evenodd" d="M.146 8.354a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L1.707 7.5H10.5a.5.5 0 0 1 0 1H1.707l2.147 2.146a.5.5 0 0 1-.708.708z" />
                        </svg>
                        <p class="Yekan-Bakh-FaNum mt-1" style="font-size: 1.3rem">
                            خروج
                        </p>
                    </div>

                </form>
            </div>
        </div>
        <div class="col-12 col-lg-10 bg-white pt-2 mt-2 pt-lg-0 mt-lg-0" style="border-top-right-radius: 35px">
            @RenderBody()
        </div>
    </div>
</body>

<script src="
https://cdn.jsdelivr.net/npm/sweetalert2@11.10.7/dist/sweetalert2.all.min.js
"></script>
<script type="text/javascript">
    import Swal from 'sweetalert2';
</script>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)


</html>