@using System.Security.Claims
@model ProfileUserVM
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}
@section css {
    <style>
        .side-item-1 {
            border-radius: 10px;
            background-color: rgba(111, 184, 243, 0.137);
            color: rgb(65, 159, 236);
        }

            .side-item-1 svg {
                color: rgb(65, 159, 236);
            }

        .b {
            border-left: 1px dashed #d3d4d4;
        }
    </style>
}
<div class="d-md-flex mt-5 mb-5" style="
            margin: 0px 10%;
            background-color: #f3f4f6;
            border-radius: 12px;
          ">
    <div class="col-12 col-md-3 box-data p-3 b">
        <h5 class="iransans mb-3">دوره ها</h5>
        <p class="Yekan-Bakh-FaNum">@Model.CourseCount دوره</p>
    </div>
    <div class="col-12 col-md-3 box-data p-3 b">
        <h5 class="iransans mb-3">نظر ها</h5>
        <p class="Yekan-Bakh-FaNum">@Model.CommentCount نظر</p>
    </div>
    <div class="col-12 col-md-3 box-data p-3 b">
        <h5 class="iransans mb-3">پرسش ها</h5>
        <p class="Yekan-Bakh-FaNum">@Model.QuestionCount پرسش</p>
    </div>
    <div class="col-12 col-md-3 box-data p-3">
        <h5 class="iransans mb-3">پاسخ ها</h5>
        <p class="Yekan-Bakh-FaNum">@Model.AnswerCount پاسخ</p>
    </div>
</div>
<div class="row" style="margin: 0px 5%; gap: 16%">
    <div class="col-12 col-md-5">
        <div class="col-12 p-3 border-box">
            <div class="d-flex" style="position: relative">
                <h3 class="vair">اطلاعات کاربر</h3>
                <a asp-action="Edit">
                    <div class="d-flex" style="position: absolute; top: 7px; left: 0px">
                        <p class="Yekan-Bakh-FaNum-Heavy">ویرایش اطلاعات</p>
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                             class="bi bi-box-arrow-in-left" viewBox="0 0 16 16">
                            <path fill-rule="evenodd"
                                  d="M10 3.5a.5.5 0 0 0-.5-.5h-8a.5.5 0 0 0-.5.5v9a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5v-2a.5.5 0 0 1 1 0v2A1.5 1.5 0 0 1 9.5 14h-8A1.5 1.5 0 0 1 0 12.5v-9A1.5 1.5 0 0 1 1.5 2h8A1.5 1.5 0 0 1 11 3.5v2a.5.5 0 0 1-1 0z" />
                            <path fill-rule="evenodd"
                                  d="M4.146 8.354a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5H14.5a.5.5 0 0 1 0 1H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3z" />
                        </svg>
                    </div>
                </a>
            </div>
            <div class="d-flex mt-4" style="margin-right: 5% ; position:relative;">
                <div class="profile-image" style=" margin-left: 5%">
                    <!-- Button trigger modal -->
                    <div class="btn-modal" data-bs-toggle="modal" data-bs-target="#exampleModal">
                        <img style="border-radius: 50% !important;" width="58px" height="58px"
                             src="./Images/9b04K1DH2DpNew697kBVLIJ9bdeIISvWAUSb3nW6.webp" alt="" />

                        <svg style="position: absolute;top: 16px;right: 16px;display:none;" xmlns="http://www.w3.org/2000/svg" width="25" height="25" fill="currentColor" class="bi bi-pencil" viewBox="0 0 16 16">
                            <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325" />
                        </svg>
                    </div>

                    <!-- Modal -->
                    <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h1 class="modal-title fs-5 vazir" id="exampleModalLabel">تغییر عکس</h1>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <input type="file" class="form-control" >
                                </div>
                                <div class="modal-footer vazir">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">انصراف</button>
                                    <button type="button" class="btn btn-primary">ثبت تصویر</button>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <div>
                    <p class="iransans">@User.FindFirstValue(ClaimTypes.GivenName)</p>
                    <p class="iransans">@Model.Email</p>
                    <a asp-action="ChangePassword" class="btn vazir">تغییر رمز عبور</a>
                </div>
            </div>
        </div>
        <div class="col-12">
            <div class="p-3 border-box">
                <div class="d-flex mb-1" style="position: relative">
                    <h3 class="vair">دیدگاه ها</h3>
                    <a asp-action="comments">

                        <div class="d-flex" style="position: absolute; top: 7px; left: 0px">
                            <p class="Yekan-Bakh-FaNum-Heavy">همه ی دیدگاه ها</p>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                 class="bi bi-box-arrow-in-left" viewBox="0 0 16 16">
                                <path fill-rule="evenodd"
                                      d="M10 3.5a.5.5 0 0 0-.5-.5h-8a.5.5 0 0 0-.5.5v9a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5v-2a.5.5 0 0 1 1 0v2A1.5 1.5 0 0 1 9.5 14h-8A1.5 1.5 0 0 1 0 12.5v-9A1.5 1.5 0 0 1 1.5 2h8A1.5 1.5 0 0 1 11 3.5v2a.5.5 0 0 1-1 0z" />
                                <path fill-rule="evenodd"
                                      d="M4.146 8.354a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5H14.5a.5.5 0 0 1 0 1H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3z" />
                            </svg>
                        </div>
                    </a>

                </div>
                @foreach (var item in Model.comments)
                {
                    <hr />
                    <a asp-controller="home" asp-action="Details" asp-route-Id="@item.CourseId">
                        <div class="mt-3">
                            <p class="Yekan-Bakh-FaNum-Heavy text-black-50">@item.Title</p>
                        </div>
                    </a>
                }
            </div>
        </div>

    </div>
    <div class="col-12 col-md-5">
        <div class="col-12">
            <div class="p-3 border-box">
                <div class="d-flex" style="position: relative">
                    <h3 class="vair">دوره ها</h3>
                    <a asp-action="courses">
                        <div class="d-flex" style="position: absolute; top: 7px; left: 0px">
                            <p class="Yekan-Bakh-FaNum-Heavy">همه ی دوره ها</p>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                 class="bi bi-box-arrow-in-left" viewBox="0 0 16 16">
                                <path fill-rule="evenodd"
                                      d="M10 3.5a.5.5 0 0 0-.5-.5h-8a.5.5 0 0 0-.5.5v9a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5v-2a.5.5 0 0 1 1 0v2A1.5 1.5 0 0 1 9.5 14h-8A1.5 1.5 0 0 1 0 12.5v-9A1.5 1.5 0 0 1 1.5 2h8A1.5 1.5 0 0 1 11 3.5v2a.5.5 0 0 1-1 0z" />
                                <path fill-rule="evenodd"
                                      d="M4.146 8.354a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5H14.5a.5.5 0 0 1 0 1H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3z" />
                            </svg>
                        </div>
                    </a>
                </div>
                @foreach (var item in Model.courses)
                {
                    <hr />
                    <a asp-controller="home" asp-action="Details" asp-route-Id="@item.Id">
                        <div class="mt-3">
                            <p class="Yekan-Bakh-FaNum-Heavy text-black-50">@item.Name</p>
                        </div>
                    </a>
                }
            </div>
        </div>
        <div class="col-12">
            <div class="p-3 border-box">
                <div class="d-flex" style="position: relative">
                    <h3 class="vair">پرسش ها</h3>
                    <a asp-action="questions">
                        <div class="d-flex" style="position: absolute; top: 7px; left: 0px">
                            <p class="Yekan-Bakh-FaNum-Heavy">همه ی پرسش ها</p>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                 class="bi bi-box-arrow-in-left" viewBox="0 0 16 16">
                                <path fill-rule="evenodd"
                                      d="M10 3.5a.5.5 0 0 0-.5-.5h-8a.5.5 0 0 0-.5.5v9a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5v-2a.5.5 0 0 1 1 0v2A1.5 1.5 0 0 1 9.5 14h-8A1.5 1.5 0 0 1 0 12.5v-9A1.5 1.5 0 0 1 1.5 2h8A1.5 1.5 0 0 1 11 3.5v2a.5.5 0 0 1-1 0z" />
                                <path fill-rule="evenodd"
                                      d="M4.146 8.354a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5H14.5a.5.5 0 0 1 0 1H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3z" />
                            </svg>
                        </div>
                    </a>
                </div>
                @foreach (var item in Model.questions)
                {
                    <hr />
                    <a asp-controller="questions" asp-action="index" asp-route-Id="@item.Id">
                        <div class="mt-3">
                            <p class="Yekan-Bakh-FaNum-Heavy text-black-50">@item.Title</p>
                        </div>
                    </a>
                }
            </div>
        </div>

    </div>
</div>

