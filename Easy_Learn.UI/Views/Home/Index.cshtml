@model List<CourseListVM>
@{
    ViewData["Title"] = "Home Page";
}
@section css{
    <link href="~/css/index.css" rel="stylesheet" />
    <link href="~/css/covernew.css" rel="stylesheet" />
    <link href="~/css/course.css" rel="stylesheet" />
}

<partial name="_CoverPartial"></partial>

<div class="container-lg course">
    <div class="d-flex" style="margin-bottom: 9%;">
        <div class="col-12 col-md-3 d-flex">
            <svg style="--tw-text-opacity: 1;color: rgba(100,116,139,var(--tw-text-opacity));margin-left: 1%;"
                 width="37" height="34" viewBox="0 0 37 34" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="10" cy="24" r="10" fill="currentColor"></circle>
                <circle cx="30" cy="13" r="7" fill="currentColor" fill-opacity="0.4"></circle>
                <circle cx="15" cy="4" r="4" fill="currentColor" fill-opacity="0.7"></circle>
            </svg>
            <div>
                <p style="font-family: 'Yekan Bakh FaNum Heavy', Helvetica;
                    font-weight: 400;
                    color: #334155;
                    font-size: 2.2rem;">جدیدترین دوره ها</p>
            </div>
        </div>
        <!-- <div class="col-12 col-md-3 d-flex">
            <div>
                <p>مشاهده همه دوره ها</p>
            </div>

        </div> -->
    </div>
    <div class="row">
        @foreach (var course in Model)
        {
            <partial name="_CoursePartial" model="course"></partial>
        }
    </div>
</div>

<div class="container-lg Teacher mt-3 d-flex">
    <div class="col-12 col-lg-7" style="margin-top: 10%;text-align: center;">
        <p style="font-family: 'Yekan Bakh FaNum';
            font-weight: 600;
            font-size: 1.6rem;">تدریس در ایزی لرن</p>
        <p style="    font-family: 'Yekan Bakh FaNum';
            font-size: 1.25rem;
            color: rgb(134, 141, 153);
            font-weight: 400;">
            برای همکاری آموزشی،تدریس و ارائه آموزش در ایزی لرن و پیوستن به آن به لینک زیر مراجعه
            کنید
        </p>
        <a asp-controller="Home" asp-action="RequestTeacher" class="link-29" style="margin-right: 0px !important;">
            <svg width="23" height="19" viewBox="0 0 23 19" fill="none" xmlns="http://www.w3.org/2000/svg">
                <g clip-path="url(#clip0_1017_42910)">
