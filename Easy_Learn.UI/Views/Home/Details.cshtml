                        </a>
                    </div>
                }
                @if (!Model.IsFree)
                {
                    <div class="col-12 mt-lg-0 mt-2 col-lg-5 d-lg-flex">
                        <p class="price">
                            @Model.Price.ToString("n0")
                        </p>
                        <img class="SVG-17 m-2" src="~/Images/TOMAN.svg">
                    </div>
                }

            </div>
        </div>
        <div class="col-12 col-lg-4">
            <img class="img-course" src="~/Images/course/@Model.Image" alt="">
        </div>

    </div>
    <hr class="mx-md-4" style="border:1px dashed" />
    <div class="d-md-flex gap-3 gap-lg-4 px-md-5">
        <div>
            <a class="d-flex gap-1" href="#comments">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="size-6 text-black">
                    <path d="M4.913 2.658c2.075-.27 4.19-.408 6.337-.408 2.147 0 4.262.139 6.337.408 1.922.25 3.291 1.861 3.405 3.727a4.403 4.403 0 0 0-1.032-.211 50.89 50.89 0 0 0-8.42 0c-2.358.196-4.04 2.19-4.04 4.434v4.286a4.47 4.47 0 0 0 2.433 3.984L7.28 21.53A.75.75 0 0 1 6 21v-4.03a48.527 48.527 0 0 1-1.087-.128C2.905 16.58 1.5 14.833 1.5 12.862V6.638c0-1.97 1.405-3.718 3.413-3.979Z" />
                    <path d="M15.75 7.5c-1.376 0-2.739.057-4.086.169C10.124 7.797 9 9.103 9 10.609v4.285c0 1.507 1.128 2.814 2.67 2.94 1.243.102 2.5.157 3.768.165l2.782 2.781a.75.75 0 0 0 1.28-.53v-2.39l.33-.026c1.542-.125 2.67-1.433 2.67-2.94v-4.286c0-1.505-1.125-2.811-2.664-2.94A49.392 49.392 0 0 0 15.75 7.5Z" />
                </svg>

                <p class="text-black">@Model.Comments.Count</p>
            </a>
        </div>
        <div>
            <a class="d-flex gap-1" href="#videos">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="size-6 text-black">
                    <path d="M4.5 4.5a3 3 0 0 0-3 3v9a3 3 0 0 0 3 3h8.25a3 3 0 0 0 3-3v-9a3 3 0 0 0-3-3H4.5ZM19.94 18.75l-2.69-2.69V7.94l2.69-2.69c.944-.945 2.56-.276 2.56 1.06v11.38c0 1.336-1.616 2.005-2.56 1.06Z" />
                </svg>

                <p class="text-black">@Model.Number_Video</p>
            </a>
        </div>
    </div>
</div>
<div class="container">
    <div class="d-flex row mt-5 ">
        <div class="col-12 col-lg-3">
            <div class="bg-white d-flex" style="border-radius: 8px;">
                <div class="col-4" style="text-align: center;border-left: #eceeef 2px solid;">
                    <div class="icon mt-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 25 25" fill="none">
                            <g clip-path="url(#clip0_149_278)">
                                <path fill-rule="evenodd" clip-rule="evenodd"
                                      d="M12.3639 24.2517C2.72515 24.2517 0.659302 22.1858 0.659302 12.5471C0.659302 2.90838 2.72515 0.842529 12.3639 0.842529C22.0025 0.842529 24.0684 2.90838 24.0684 12.5471C24.0684 22.1858 22.0025 24.2517 12.3639 24.2517ZM11.3885 6.6948C11.3885 6.15609 11.8252 5.71942 12.3639 5.71942C12.9025 5.71942 13.3392 6.15609 13.3392 6.6948V11.5717H18.2161C18.7548 11.5717 19.1915 12.0084 19.1915 12.5471C19.1915 13.0858 18.7548 13.5225 18.2161 13.5225H12.3639C11.8252 13.5225 11.3885 13.0858 11.3885 12.5471V6.6948Z"
