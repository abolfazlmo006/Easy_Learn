                        border-color: #22c55e;
                        font-size: 1.125rem;
                        line-height: 1.75rem;
                        font-family: 'Yekan Bakh FaNum';
                        font-weight: 700;" onclick="AddToCart(event,'@User.FindFirstValue(ClaimTypes.NameIdentifier)',@Model.Id)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="20" viewBox="0 0 24 20"
                                 fill="none">
                                <g clip-path="url(#clip0_149_208)">
                                    <path d="M5.3276 10.2747C11.5469 13.882 12.3247 13.8821 18.544 10.2747C24.7634 6.66746 24.7634 6.66746 18.544 3.06019C12.3247 -0.547076 11.5469 -0.547086 5.3276 3.06019C2.21793 4.86383 0.663086 5.76565 0.663086 6.66747V14.7839C0.663086 15.2819 1.06684 15.6857 1.5649 15.6857C2.06296 15.6857 2.46672 15.2819 2.46672 14.7839V8.89807C2.46672 8.75515 2.62521 8.66863 2.74626 8.74462C3.43561 9.17737 4.29606 9.67644 5.3276 10.2747Z"
                                          fill="white" />
                                    <path d="M5.3275 11.1768C11.5468 14.784 12.3246 14.784 18.5439 11.1768L18.8987 10.9709C19.1802 10.8075 19.5352 10.9867 19.5559 11.3116C19.5872 11.8026 19.6011 12.3562 19.6011 12.9803C19.6011 17.4894 17.7975 18.3913 11.9047 18.3913C5.61774 18.3913 4.27026 17.4894 4.27026 12.9803C4.27026 12.3565 4.28363 11.8031 4.31379 11.3123C4.33379 10.9867 4.68936 10.8064 4.97149 10.9702L5.3275 11.1768Z"
