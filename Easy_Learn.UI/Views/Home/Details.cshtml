@model CourseDetailVM
@{
    ViewData["Title"] = "Details";
    var i = 0;
}
@section css {
    <link href="~/css/detail.css" rel="stylesheet" />
}

<div class="bg-white title-box mt-4 container" style="border-radius: 8px;">
    <div class="d-flex" style="gap:60px;flex-wrap:wrap">
        <div class="col-12 col-lg-7 txt-title-course">
            <p class="title-text-course">
                @Model.Name
            </p>
            <p class="txt-title-description-course bug-txt">
                @Model.Short_Description
            </p>
            <div class="d-lg-flex mx-lg-5">
                @if (Model.IsFree)
                {
                    <div class="col-12 col-lg-7">
                        <a href="#" class="p-2" style="text-decoration: none;color: white;background-color: #22c55e;
                        border-radius: 4px;
                        border: 1px solid;
                        border-color: #22c55e;
                        font-size: 1.125rem;
                        line-height: 1.75rem;
                        font-family: 'Yekan Bakh FaNum';
                        font-weight: 700;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="20" viewBox="0 0 24 20"
                                 fill="none">
                                <g clip-path="url(#clip0_149_208)">
                                    <path d="M5.3276 10.2747C11.5469 13.882 12.3247 13.8821 18.544 10.2747C24.7634 6.66746 24.7634 6.66746 18.544 3.06019C12.3247 -0.547076 11.5469 -0.547086 5.3276 3.06019C2.21793 4.86383 0.663086 5.76565 0.663086 6.66747V14.7839C0.663086 15.2819 1.06684 15.6857 1.5649 15.6857C2.06296 15.6857 2.46672 15.2819 2.46672 14.7839V8.89807C2.46672 8.75515 2.62521 8.66863 2.74626 8.74462C3.43561 9.17737 4.29606 9.67644 5.3276 10.2747Z"
