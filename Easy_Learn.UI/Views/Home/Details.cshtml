                                      fill="#3B82F6" />
                            </g>
                            <defs>
                                <clipPath id="clip0_149_278">
                                    <rect width="24" height="24" fill="white"
                                          transform="translate(0.184692 0.318359)" />
                                </clipPath>
                            </defs>
                        </svg>
                    </div>
                    <p style="font-size: .75rem;
                                line-height: 1rem;
                                font-family: 'Yekan Bakh FaNum';
                                color: rgb(134, 141, 153);margin-top: 0.5rem;">
                        آخرین آپدیت دوره
                    </p>
                    <p style="font-size: 1rem;
                    font-family: 'Yekan Bakh FaNum';
                    font-weight: 700;">
                        @Model.UpdateTime.Year/@Model.UpdateTime.Month/@Model.UpdateTime.Day
                    </p>
                </div>
                <div class="col-4" style="text-align: center;">
                    <div class="icon mt-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 25 25" fill="none">
                            <g clip-path="url(#clip0_149_278)">
                                <path fill-rule="evenodd" clip-rule="evenodd"
                                      d="M12.3639 24.2517C2.72515 24.2517 0.659302 22.1858 0.659302 12.5471C0.659302 2.90838 2.72515 0.842529 12.3639 0.842529C22.0025 0.842529 24.0684 2.90838 24.0684 12.5471C24.0684 22.1858 22.0025 24.2517 12.3639 24.2517ZM11.3885 6.6948C11.3885 6.15609 11.8252 5.71942 12.3639 5.71942C12.9025 5.71942 13.3392 6.15609 13.3392 6.6948V11.5717H18.2161C18.7548 11.5717 19.1915 12.0084 19.1915 12.5471C19.1915 13.0858 18.7548 13.5225 18.2161 13.5225H12.3639C11.8252 13.5225 11.3885 13.0858 11.3885 12.5471V6.6948Z"
                                      fill="#3B82F6" />
                            </g>
                            <defs>
                                <clipPath id="clip0_149_278">
                                    <rect width="24" height="24" fill="white"
                                          transform="translate(0.184692 0.318359)" />
                                </clipPath>
                            </defs>
                        </svg>
                    </div>
                    <p style="font-size: .75rem;
                                line-height: 1rem;
                                font-family: 'Yekan Bakh FaNum';
                                color: rgb(134, 141, 153);margin-top: 0.5rem;">
                        ساخت دوره
                    </p>
                    <p style="font-size: 1rem;
                    font-family: 'Yekan Bakh FaNum';
                    font-weight: 700;">
                        @Model.CreateTime.Year/@Model.CreateTime.Month/@Model.CreateTime.Day
                    </p>
                </div>
            </div>
            <div class="mt-4 bg-white w-100 pt-3 pb-2" style="border-radius: 8px;">
                <div style="text-align: center;">
                    <div>
                        <img style="border-radius: 50%!important;" width="58px" height="58px"
                             src="~/Images/9b04K1DH2DpNew697kBVLIJ9bdeIISvWAUSb3nW6.webp" alt="">
                    </div>
                    <p style="font-size: 1.28rem;
                    font-family: 'Yekan Bakh FaNum';
                    font-weight: 700;margin: 0;">@Model.Teacher_Name</p>

                    <p style="font-size: 1rem;
                    line-height: 1rem;
                    font-family: 'Yekan Bakh FaNum';
                    color: rgb(134, 141, 153);">مدرس دوره</p>

                </div>

            </div>
            <div class="mt-4" style="border-radius: 8px;
            border: 1px solid rgba(210, 214, 222, 0.60);text-align: center;">
                <img style="width: 118px; height: 100px;margin: auto;" src="~/Images/message.png" alt="">
                <p style="font-weight: 700;font-size: 1.5rem;
                line-height: 2rem;font-family: 'Yekan Bakh FaNum';">
                    گفتگوی‌ برنامه نویسان
                </p>
                <p style="font-size: 1rem;
                line-height: 1rem;
                font-family: 'Yekan Bakh FaNum';
                color: rgb(134, 141, 153);line-height: 1.5rem;">
                    برای پرسش و پاسخ سوالات برنامه نویسی مربوط به این دوره کلیک کنید
                </p>

                <p>
                    <a href="/Details/@Model.Id/Questions" class="vazir ">پرسش و پاسخ</a>
                </p>
            </div>
        </div>
        <div class="col-12 col-lg-9">
            <div class="bg-white pb-1 pt-4 px-2" style="border-radius: 8px;">
                <div class="d-flex" style="margin-right: 2%;gap: 9px;">
                    <div style="width: 8px; height: 8px;border-radius: 9999px;background: #3B82F6;margin-top: 22px; ">
                    </div>
                    <h4 style="font-weight: 700;font-size: 1.75rem;font-family: 'Yekan Bakh FaNum';color: #3B82F6;    margin-top: 13px;">
                        توضیحات
                    </h4>
                </div>
                <div style="text-align:center;" class="my-2 mx-4 mx-lg-5">
                    <p class="bug-txt" style="font-family: 'Yekan Bakh FaNum';
                    font-size: 1.35rem;
                    color: rgb(134, 141, 153);
                    font-weight: 500;">
                        @Model.Description
                    </p>
                </div>
            </div>
            <div class="bg-white mt-4 pb-1 pt-4 px-2" style="border-radius: 8px;">
                <div class="d-flex" style="margin-right: 2%;gap: 9px;">
                    <div style="width: 8px; height: 8px;border-radius: 9999px;background: #3B82F6;margin-top: 22px; ">
                    </div>
                    <h4 style="font-weight: 700;font-size: 1.75rem;font-family: 'Yekan Bakh FaNum';color: #3B82F6;    margin-top: 13px;">
                        پیشنیاز ها
                    </h4>
                </div>
                <div style="margin: 20px 50px;">
                    <ul style="font-size: 1.25rem;font-weight: 600;font-family: 'Yekan Bakh FaNum';--tw-text-opacity: 1;
                    color: rgba(75,90,120,var(--tw-text-opacity)); list-style-type:square;">
                        @if (Model.Prerequisites.Count != 0)
                        {
                            @foreach (var item in Model.Prerequisites)
                            {
                                <li>@item</li>
                            }
                        }
                        else
                        {
                            <p class="alert alert-info">پیشنیازی ندارد</p>
                        }
                    </ul>
                </div>
            </div>
            <div id="videos" class="bg-white mt-4 pb-1 pt-4 px-2" style="border-radius: 8px;">
                <div class="d-flex" style="margin-right: 2%;gap: 9px;">
                    <div style="width: 8px; height: 8px;border-radius: 9999px;background: #3B82F6;margin-top: 22px; ">
                    </div>
                    <h4 style="font-weight: 700;font-size: 1.75rem;font-family: 'Yekan Bakh FaNum';color: #3B82F6;    margin-top: 13px;">
                        جلسات دوره
                    </h4>
                </div>
                <div class="my-2 mx-lg-4">
                    <div class="video-course">
                        @if (Model.Videos.Count == 0)
                        {
                            <p class="alert alert-info vazir">به زودی</p>
                        }
                        @foreach (var item in Model.Videos)
                        {
                            <div class="accordion-item mt-4 mb-3 mx-5">
                                <h2 class="accordion-header">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#flush-collapse-@(++i)" aria-expanded="false" aria-controls="flush-collapse-@(i)">
                                        <p style="font-size: 1.25rem;font-weight: 600;font-family: 'Yekan Bakh FaNum';--tw-text-opacity: 1;
                        color: rgba(75,90,120,var(--tw-text-opacity));">
                                            @item.Title_Video
                                        </p>
                                    </button>
                                </h2>
                                <div id="flush-collapse-@(i)" class="accordion-collapse collapse" data-bs-parent="#accordionFlushExample">
                                    <div class="accordion-body">
                                        @if (!User.Identity.IsAuthenticated)
                                        {
                                            <p class="alert alert-danger vazir">برای دیدن ویدیو باید وارد سایت شوید</p>
                                        }
                                        else if (!Model.IsStudent)
                                        {
                                            <p class="alert alert-danger vazir">شما دانشجوی دوره نیستید</p>
                                        }
                                        else
                                        {
                                            <video controls="controls" width="100%">
                                                <source src="~/Videos/@item.Address_Video" type="video/mp4" />
                                            </video>
                                        }

                                    </div>
                                </div>
                            </div>
                        }

                    </div>
                </div>
            </div>
            <div id="comments" class="bg-white mt-4 pb-1 pt-4 px-2" style="border-radius: 8px;">
                <div class="d-flex" style="margin-right: 2%;gap: 9px;">
                    <div style="width: 8px; height: 8px;border-radius: 9999px;background: #3B82F6;margin-top: 22px; ">
                    </div>
                    <h4 style="font-weight: 700;font-size: 1.75rem;font-family: 'Yekan Bakh FaNum';color: #3B82F6;    margin-top: 13px;">
                        دیدگاه
                    </h4>
                </div>
                @if (User.Identity.IsAuthenticated)
                {
                    @if ((Model.IsFree || Model.IsStudent))
                    {
                        <div id="CreateForm" class="col-12 comment-box mb-3 vazir pt-0" style="box-shadow:none">
                            <ul class="text-danger" id="errors">
                            </ul>
                            <h2>ارسال نظر</h2>
                            <textarea placeholder="نظر خود را اینجا بنویسید..." asp-for="CreateCommentVM.Title"></textarea>
                            <span class="text-danger" id="titleError"></span>
                            <br />
                            <label>فقط مدرس دوره می تواند این نظر را بخواند</label>
                            <input type="checkbox" asp-for="CreateCommentVM.Private">
                            <br />
                            <button onclick="create(event,'@User.FindFirstValue(ClaimTypes.NameIdentifier)',@Model.Id)" class="button">ارسال</button>
                        </div>

                        <div id="EditForm" class="col-12 comment-box mb-3 vazir pt-0" style="box-shadow:none;display:none">
                            <ul class="text-danger" id="errorsEdit">
                            </ul>
                            <h2>ویرایش نظر</h2>
                            <input type="hidden" id="commentId" />
                            <textarea placeholder="نظر خود را اینجا بنویسید..." asp-for="UpdateCommentVM.Title"></textarea>
                            <span class="text-danger" id="titleErrorEdit"></span>
                            <br />
                            <button onclick="update(event,'@User.FindFirstValue(ClaimTypes.NameIdentifier)')" class="button">ثبت</button>
                            <div style="display:inline" onclick="cancelEdit(event)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-x" viewBox="0 0 16 16">
                                    <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708" />
                                </svg>
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="alert alert-danger vazir">برای نظر دادن باید دوره را بخرید</p>
                    }
                }
                else
                {
                    <p class="alert alert-danger vazir">برای نظر دادن باید وارد سایت شوید</p>
                }




                <div class="comments-course row">
                    @foreach (var item in Model.Comments)
                    {
                        <partial name="_CommentPartial" model="item"></partial>
                    }
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script type="text/javascript" src="~/build/ckeditor.js"></script>
    <script src="~/js/signalr/dist/browser/signalr.min.js"></script>
    <script type="text/javascript" src="~/js/Details.js"></script>
}