@model Easy_Learn.UI.ViewModels.TeacherVM.RequestForTeacherVM

@{
    ViewData["Title"] = "درخواست تدریس";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 vazir">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="card-title mb-0">فرم درخواست تدریس</h3>
                </div>
                <div class="card-body">
                    <form asp-action="RequestTeacher" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="form-group mb-4">
                            <label asp-for="Descrption" class="form-label fw-bold">توضیحات</label>
                            <textarea asp-for="Descrption" class="form-control" rows="4" placeholder="دلایل و توضیحات خود را بنویسید..." required></textarea>
                            <span asp-validation-for="Descrption" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-4">
                                    <label asp-for="Mobile" class="form-label fw-bold">شماره موبایل</label>
                                    <input asp-for="Mobile" class="form-control" placeholder="09xxxxxxxxx" required>
                                    <span asp-validation-for="Mobile" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-4">
                                    <label asp-for="Email" class="form-label fw-bold">ایمیل</label>
                                    <input asp-for="Email" class="form-control" placeholder="example@domain.com" required>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Address_Resumes" class="form-label fw-bold">توضیحات</label>
                            <input asp-for="Address_Resumes" class="form-control" rows="4"  required/>
                            <span asp-validation-for="Address_Resumes" class="text-danger small"></span>
                        </div>

                        <div class="form-group mt-4">
                            <button type="submit" class="btn btn-success w-100 py-2">
                                <i class="fas fa-paper-plane me-2"></i>ارسال درخواست
                            </button>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-light">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-right me-2"></i>بازگشت به لیست
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section css {
    <style>
        
        .card {
            border-radius: 15px;
            border: none;
        }

        .form-control {
            border-radius: 10px;
            border: 1px solid #ced4da;
            transition: all 0.3s;
        }

            .form-control:focus {
                border-color: #80bdff;
                box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
            }

        .btn-success {
            background-color: #28a745;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-success:hover {
                background-color: #218838;
                transform: translateY(-2px);
            }
    </style>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}