@model Easy_Learn.UI.ViewModels.CommentVM.UpdateCommentVM

@{
    ViewData["Title"] = "Edit";
}

<div class="container-md">
    <div class="col-md-4">
        <form asp-action="Edit" method="post" asp-route-Id="@ViewData["CommentId"]" asp-route-courseId="@ViewData["CourseId"]">
            @if (ViewBag.error != null)
            {
                <ul class="text-danger">
                    @foreach (var item in ViewBag.error)
                    {
                        <li>
                            @item
                        </li>
                    }
                </ul>
            }
            else if (ViewBag.Message != null)
            {
                <p class="text-danger">@ViewBag.Message</p>
            }
            <div class="form-group">
                <label asp-for="Title" class="control-label"></label>
                <textarea asp-for="Title" class="form-control" rows="6"></textarea>
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
